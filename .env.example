# App environment. Accepted values: development | staging | production
APP_ENV=development

# Enables /debug/sentry in staging for temporary onboarding smoke tests. Ignored in production.
ENABLE_SENTRY_DEBUG_ROUTE=false

DATABASE_URL="postgresql://username:password@hostname:5432/database?sslmode=require"

RESEND_API_KEY=re_xxxxxxxxxxxx
# Email address that receives contact form submissions
CONTACT_EMAIL=you@example.com
# Sender address for contact notification emails — must match a verified Resend domain
CONTACT_FROM_EMAIL=noreply@your-domain.com

SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# Optional — required only when uploading Sentry source maps during CI/deploy
# SENTRY_ORG=your-sentry-org
# SENTRY_PROJECT=your-sentry-project
# SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxx

BETTER_AUTH_SECRET=change-me-must-be-at-least-32-characters-long
BETTER_AUTH_URL=https://your-domain.com

# Optional — used for metadataBase and sitemap URLs. Public, not a secret.
# SITE_URL=https://your-domain.com

# Optional — defaults to "info". Accepted values: trace | debug | info | warn | error | fatal | silent
# LOG_LEVEL=info

# A populated .env file is required to run db:generate and db:migrate.
# drizzle.config.ts loads this file via dotenv/config at runtime.
